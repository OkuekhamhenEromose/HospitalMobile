{
  "expo": {
    "name": "Lumen",
    "slug": "etha-atlantic-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1378e5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lumen.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-1024.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lumen.mobile",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-dev-client"
    ],
    "extra": {
      "eas": {
        "projectId": "c1b119e6-949d-497a-bc58-e259f77e0075"
      }
    }
  }
}