{
  "expo": {
    "name": "Etha-Atlantic Memorial",
    "slug": "etha-atlantic-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1378e5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ethaatlantic.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-1024.png",
        "backgroundColor": "#1378e5"
      },
      "package": "com.ethaatlantic.mobile"
    },
    "web": {
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "c1b119e6-949d-497a-bc58-e259f77e0075"
      }
    }
  }
}
